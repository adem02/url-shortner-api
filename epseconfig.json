{
  "projectName": "url-shortner-api",
  "projectType": "lite",
  "controllersPath": "src/controllers",
  "database": true,
  "auth": false,
  "routes": [
    {
      "domain": "health",
      "routeBasePath": "api/health"
    },
    {
      "domain": "shortner",
      "routeBasePath": "api/shorten"
    },
    {
      "domain": "click",
      "routeBasePath": "/"
    }
  ],
  "customMiddlewares": [
    {
      "name": "ShortenUrlRateLimitMiddleware"
    }
  ]
}
